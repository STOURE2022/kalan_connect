# ══════════════════════════════════════════════
# KalanConnect — Variables d'environnement PRODUCTION
# Copier ce fichier en .env dans le dossier docker/
# ══════════════════════════════════════════════

# ── Django ──
SECRET_KEY=GENERER_UNE_CLE_SECRETE_AVEC_python_-c_"from_django.core.management.utils_import_get_random_secret_key;print(get_random_secret_key())"
ALLOWED_HOSTS=kalanconnect.ml,www.kalanconnect.ml
DOMAIN=kalanconnect.ml

# ── Base de données PostgreSQL ──
DB_NAME=kalanconnect
DB_USER=kalanconnect_user
DB_PASSWORD=CHANGER_CE_MOT_DE_PASSE_FORT

# ── Redis ──
REDIS_PASSWORD=CHANGER_CE_MOT_DE_PASSE_REDIS

# ── Orange Money ──
ORANGE_MONEY_CLIENT_ID=votre_client_id
ORANGE_MONEY_CLIENT_SECRET=votre_client_secret
ORANGE_MONEY_MERCHANT_KEY=votre_merchant_key
ORANGE_MONEY_WEBHOOK_SECRET=votre_webhook_secret

# ── Firebase (notifications push) ──
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json
