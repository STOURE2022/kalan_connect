# KalanConnect Mobile — Environment Variables
# Copy to .env and fill in values

# API Base URL (use 10.0.2.2 for Android emulator, localhost for iOS simulator)
API_URL=http://10.0.2.2:8000/api/v1
WS_URL=ws://10.0.2.2:8000

# Firebase (Push Notifications)
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=kalanconnect
FIREBASE_SENDER_ID=
