# KalanConnect — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs

DEBUG=True
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Base de données PostgreSQL
DB_NAME=kalanconnect
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# Orange Money
ORANGE_MONEY_MERCHANT_KEY=your_merchant_key
ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay/ml/v1
ORANGE_MONEY_RETURN_URL=https://kalanconnect.ml/payment/success
ORANGE_MONEY_CANCEL_URL=https://kalanconnect.ml/payment/cancel
ORANGE_MONEY_NOTIF_URL=https://api.kalanconnect.ml/api/v1/payments/webhook/orange-money/

# Firebase (Push Notifications)
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# SMS (Africa's Talking)
AT_USERNAME=sandbox
AT_API_KEY=your_api_key

# Allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,kalanconnect.ml
